{
    "version": "1.19.1b",
    "description": "(Scoop bucket by arch3rpro) Zen-Browser - A open-source browser based on the Firefox engine",
    "homepage": "https://zen-browser.app/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.19.1b/zen.installer.exe#/dl.7z",
            "hash": "e0b32df95d1761c398018992a5e2fb39755a8be04a73ea3264e4cea45b55b4eb"
        },
        "arm64": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.19.1b/zen.installer-arm64.exe#/dl.7z",
            "hash": "7530184b48bc910dc6f8ea7c770412d874b4b31350cb5895086a799b90554b19"
        }
    },
    "extract_dir": "core",
    "post_install": [
        "zen -CreateProfile \"Scoop $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "bin": "zen.exe",
    "shortcuts": [
        [
            "zen.exe",
            "Zen"
        ],
        [
            "private_browsing.exe",
            "Zen Private Browsing"
        ],
        [
            "zen.exe",
            "Zen Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/releases/latest",
        "regex": "/releases/tag/?([\\d.]+b)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/dl.7z",
                "hash": {
                    "url": "https://github.com/zen-browser/desktop/releases/latest",
                    "regex": "$sha256\\s+zen.installer.exe"
                }
            },
            "arm64": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer-arm64.exe#/dl.7z",
                "hash": {
                    "url": "https://github.com/zen-browser/desktop/releases/latest",
                    "regex": "$sha256\\s+zen.installer-arm64.exe"
                }
            }
        }
    }
}
